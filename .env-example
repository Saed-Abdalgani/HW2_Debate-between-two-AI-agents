LLM_API_KEY=
SEARCH_API_KEY=
LOG_LEVEL=INFO

# LLM Provider Configuration
# For Groq (OpenAI-compatible): set LLM_API_KEY above to your Groq key, then set:
LLM_BASE_URL=https://api.groq.com/openai/v1
# Use a current Groq model id (llama3-8b-8192 was removed Aug 2025; see Groq deprecations docs).
LLM_MODEL=llama-3.1-8b-instant
# Omit LLM_BASE_URL to use the default OpenAI API (https://api.openai.com/v1).
# Omit LLM_MODEL (or leave empty) to use model names from config/debate.json (defaults to gpt-4o-mini).
